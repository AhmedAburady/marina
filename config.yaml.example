hosts:
  gmktec:
    address: ssh://ahmed@10.0.0.50
  pve-arr:
    address: ssh://ahmed@10.0.0.51
  synology:
    address: ssh://ahmed@synology.tail
    stacks:
      media: /opt/stacks/media    # manually defined (fallback for stopped stacks)

settings:
  ssh_key: ~/.ssh/id_ed25519
  prune_after_update: true

notifications:
