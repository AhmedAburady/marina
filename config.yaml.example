hosts:
  gmktec:
    address: 10.0.0.50
  pve-arr:
    address: 10.0.0.51
  synology:
    address: synology.tail
    user: root
    ssh_key: ~/.ssh/id_rsa    # per-host key override
    stacks:
      media: /opt/stacks/media

settings:
  username: username
  ssh_key: ~/.ssh/id_ed25519    # global default SSH key
  prune_after_update: true

notifications:
  gotify:
    # Prefer https:// — the app token travels in the X-Gotify-Key header.
    # http:// works too (not enforced); your token is then sent in clear over
    # whatever network sits between marina and the Gotify server.
    url: https://gotify.yourdomain.com
    # prefer token_env over token (keeps secret out of config file)
    # token_env: MARINA_GOTIFY_TOKEN   # read token from this env var
    token: your-app-token              # stored in plaintext — keep this file 0600
    priority: 5
